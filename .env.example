# Server-only Telegram credentials. Never expose these values through VITE_* variables.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# noteapp-ai-integration proxy. The landing does not call Telegram directly.
AI_INTEGRATION_BASE_URL=https://integration.example.com
AI_INTEGRATION_API_KEY=
AI_INTEGRATION_SOCIAL_POSTS_PATH=/api/social/posts

# Runtime configuration for the Node production server.
HOST=0.0.0.0
PORT=4173

# Public site and optional analytics configuration.
VITE_SITE_URL=https://example.com
VITE_YANDEX_METRIKA_ID=
VITE_GTAG_ID=
